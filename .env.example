# Copy this file to .env. Never commit the copied file.

# Telegram: required for real delivery, but not for --dry-run or --check-config.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# eBay production application keys from developer.ebay.com.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# Optional Vinted HTTP proxy for VPS IPs that Vinted rejects.
# Formats: http://user:password@host:port or user:password@host:port.
VINTED_PROXY=

# Optional. Enables full title/description translation when translation.enabled is true.
DEEPL_API_KEY=

# Optional. Defaults to marketplace-alerts/<version>.
MONITOR_USER_AGENT=
