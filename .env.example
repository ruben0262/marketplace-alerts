# Copy this file to .env. Never commit the copied file.

# Telegram: required for real delivery, but not for --dry-run or --check-config.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# eBay production application keys from developer.ebay.com.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# Optional. Defaults to marketplace-alerts/<version>.
MONITOR_USER_AGENT=
